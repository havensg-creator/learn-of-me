---
layout: layout.njk
title: Episodes
permalink: /episodes/
description: Questions the Bible answers — each episode explores a passage through multiple trusted teachers.
---

<section class="hero" style="padding: 3rem 2rem;">
  <h1>Episodes</h1>
  <p class="verse">Questions the Bible answers — each episode takes a passage of Scripture and lays multiple trusted teachers side by side.</p>
</section>

<main>
  {% if episodes.published.length > 0 %}

    {# Category filter buttons #}
    {% set categories = [] %}
    {% for ep in episodes.published %}
      {% if ep.category and ep.category not in categories %}
        {% set categories = (categories.push(ep.category), categories) %}
      {% endif %}
    {% endfor %}

    {% if categories.length > 1 %}
    <div class="category-filters">
      <button class="cat-btn active" onclick="filterEpisodes('all')">All</button>
      {% for cat in categories %}
      <button class="cat-btn" onclick="filterEpisodes('{{ cat }}')">{{ cat }}</button>
      {% endfor %}
    </div>
    {% endif %}

    {% for ep in episodes.published | reverse %}
    <div class="episode-card" data-category="{{ ep.category }}">
      <div class="episode-card-top">
        {% if ep.category %}
        <span class="category-badge small">{{ ep.category }}</span>
        {% endif %}
      </div>
      <h3><a href="/episodes/{{ ep.slug }}/">{{ ep.question }}</a></h3>
      <div class="meta">
        <span class="passage">{{ ep.scripture }}</span>
      </div>
      <div class="teachers-list">
        {% for teacher in ep.teachers | split(",") %}
        <span class="teacher-tag">{{ teacher }}</span>
        {% endfor %}
      </div>
      {% if ep.audio_url %}
      <div class="episode-audio-badge">
        <span>&#9654; Deep dive available</span>
      </div>
      {% endif %}
    </div>
    {% endfor %}

    <script>
    function filterEpisodes(cat) {
      var cards = document.querySelectorAll('.episode-card');
      var btns = document.querySelectorAll('.cat-btn');
      btns.forEach(function(b) { b.classList.remove('active'); });
      event.target.classList.add('active');
      cards.forEach(function(c) {
        if (cat === 'all' || c.dataset.category === cat) {
          c.style.display = '';
        } else {
          c.style.display = 'none';
        }
      });
    }
    </script>

  {% else %}
  <div class="empty-state">
    <p>Episodes are on the way. The first study is being prepared now.</p>
  </div>
  {% endif %}
</main>
