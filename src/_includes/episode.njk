---
layout: layout.njk
---

<section class="hero" style="padding: 3rem 2rem;">
  <h1>{{ question }}</h1>
  <p class="verse">{{ scripture }}</p>
  {% if category %}
  <span class="category-badge">{{ category }}</span>
  {% endif %}
</section>

<main>
  <div class="episode-detail">

    {# Deep Dive Audio — the main event #}
    {% if audio_url %}
    <div class="audio-player">
      <h3 class="section-heading">Deep Dive</h3>
      <p style="font-size: 0.9rem; color: var(--muted); margin-bottom: 0.75rem;">Listen to a synthesized deep dive exploring how multiple teachers handle this passage.</p>
      <audio controls style="width: 100%;">
        <source src="{{ audio_url }}" type="audio/mpeg">
      </audio>
    </div>
    {% endif %}

    {# Teacher Sources — embedded YouTube videos #}
    {% set episodeSources = [] %}
    {% for src in episodes.sources %}
      {% if src.slug == slug %}
        {% set episodeSources = (episodeSources.push(src), episodeSources) %}
      {% endif %}
    {% endfor %}

    {% if episodeSources.length > 0 %}
    <h3 class="section-heading">Hear from the Teachers</h3>
    <p style="font-size: 0.9rem; color: var(--muted); margin-bottom: 1rem;">Watch each teacher's sermon on {{ scripture }} — then listen to the deep dive above to hear how their perspectives come together.</p>

    <div class="teacher-videos">
      {% for src in episodeSources %}
      <div class="video-card">
        <div class="video-embed">
          {% if src.video_url and "youtube.com" in src.video_url %}
            {% set videoId = src.video_url | replace("https://www.youtube.com/watch?v=", "") | replace("https://youtube.com/watch?v=", "") %}
            {% set videoId = videoId | replace("https://youtu.be/", "") %}
            {% if "&" in videoId %}
              {% set videoId = videoId.split("&")[0] %}
            {% endif %}
            <iframe src="https://www.youtube.com/embed/{{ videoId }}" title="{{ src.teacher_name }} on {{ scripture }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          {% elif src.video_url and "youtu.be" in src.video_url %}
            {% set videoId = src.video_url | replace("https://youtu.be/", "") %}
            {% if "?" in videoId %}
              {% set videoId = videoId.split("?")[0] %}
            {% endif %}
            <iframe src="https://www.youtube.com/embed/{{ videoId }}" title="{{ src.teacher_name }} on {{ scripture }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          {% else %}
            <a href="{{ src.video_url }}" target="_blank" rel="noopener" class="video-link">Watch {{ src.teacher_name }} &rarr;</a>
          {% endif %}
        </div>
        <div class="video-info">
          <strong>{{ src.teacher_name }}</strong>
          {% if src.video_title %}<span class="video-title">{{ src.video_title }}</span>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {# NotebookLM link #}
    {% if notebook_url %}
    <div style="margin-top: 2rem; text-align: center;">
      <a href="{{ notebook_url }}" target="_blank" rel="noopener" class="notebook-link">Open in NotebookLM &rarr;</a>
    </div>
    {% endif %}

    <div style="margin-top: 3rem; text-align: center;">
      <a href="/episodes/" style="font-weight: 600;">&larr; All Episodes</a>
    </div>

  </div>
</main>
